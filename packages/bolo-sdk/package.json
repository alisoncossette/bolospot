{
  "name": "@bolospot/sdk",
  "version": "0.1.0",
  "description": "TypeScript SDK for building on Bolospot — sovereign infrastructure for AI agent coordination",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "node --experimental-vm-modules node_modules/.bin/jest"
  },
  "keywords": [
    "bolo",
    "sdk",
    "permissions",
    "trust",
    "sovereign-infrastructure",
    "ai-agents",
    "relay",
    "widgets"
  ],
  "license": "MIT",
  "files": [
    "dist",
    "README.md"
  ],
  "devDependencies": {
    "@types/jest": "^29.5.11",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.1",
    "typescript": "^5.9.3"
  }
}