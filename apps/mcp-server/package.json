{
  "name": "@bolo/mcp-server",
  "version": "0.2.0",
  "description": "MCP server for Bolo — peer-to-peer digital permissions for AI agents",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "bolo-mcp": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "mcp",
    "bolo",
    "permissions",
    "grants",
    "calendar",
    "ai",
    "scheduling",
    "agent",
    "openclaw",
    "claude",
    "peer-to-peer"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "typescript": "^5.3.3",
    "tsx": "^4.7.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist/**/*"
  ]
}
